{
  "name": "uber-simulation",
  "version": "0.1.0",
  "description": "Matching competition platform — Uber-like simulation engine",
  "type": "module",
  "scripts": {
    "start": "node --env-file-if-exists=.env --import tsx src/server.ts",
    "engine": "node --env-file-if-exists=.env --import tsx src/server.ts",
    "engine:fast": "CYCLE_MS=250 node --env-file-if-exists=.env --import tsx src/server.ts",
    "client:greedy": "tsx client/greedy.ts",
    "client:dp": "tsx client/dp.ts",
    "client:dp-triage": "tsx client/dp-triage.ts",
    "client:smart": "tsx client/smart.ts",
    "client:triage": "tsx client/triage.ts",
    "client:profit": "tsx client/profit.ts",
    "client:stable": "tsx client/stable.ts",
    "client:smart-triage": "tsx client/smart-triage.ts",
    "client:nearest-driver": "tsx client/nearest-driver.ts",
    "client:nearest-trip": "tsx client/nearest-trip.ts"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "postgres": "^3.4.9",
    "tsx": "^4.22.4",
    "ws": "^8.21.0"
  }
}
