# Sample environment variables. Copy this file to .env and fill in the values.
# On Railway, instead of this file, define the variables in the service
# (preferably as a reference to the database: DATABASE_URL=${{Postgres.DATABASE_URL}}).

# Connection to Postgres for archiving finished sessions AND user accounts.
# If not set, the app falls back to an in-memory store (data lost on restart).
DATABASE_URL=postgresql://USER@localhost:5432/uber_simulation

# The engine runs at full speed (advances as soon as the matcher answers).
# If a client doesn't answer within this many ms, the cycle advances anyway so
# a slow/dead matcher can't stall the session.
# CYCLE_TIMEOUT_MS=10000
